@model Ecommerce_Modelos.ViewModels.SalesReportVM
@using Ecommerce_Modelos.ViewModels

<div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
    <h1 class="h3 m-0">Top Selling Products</h1>
    <a asp-area="Admin" asp-controller="Dashboard" asp-action="Index" class="btn btn-outline-secondary btn-sm">Volver al dashboard</a>
</div>

<div class="card p-3 mb-3">
    <div class="d-flex flex-wrap gap-2">
        <a asp-action="SalesReport" asp-route-range="@SalesReportRanges.Today" class="btn @(Model.Range == SalesReportRanges.Today ? "btn-primary" : "btn-outline-primary") btn-sm">Today</a>
        <a asp-action="SalesReport" asp-route-range="@SalesReportRanges.Last7Days" class="btn @(Model.Range == SalesReportRanges.Last7Days ? "btn-primary" : "btn-outline-primary") btn-sm">Last 7 days</a>
        <a asp-action="SalesReport" asp-route-range="@SalesReportRanges.Last30Days" class="btn @(Model.Range == SalesReportRanges.Last30Days ? "btn-primary" : "btn-outline-primary") btn-sm">Last 30 days</a>
        <a asp-action="SalesReport" asp-route-range="@SalesReportRanges.AllTime" class="btn @(Model.Range == SalesReportRanges.AllTime ? "btn-primary" : "btn-outline-primary") btn-sm">All time</a>
    </div>
    <div class="small text-muted mt-2">Rango activo: @Model.RangeLabel</div>
</div>

<div class="row g-3 mb-3">
    <div class="col-12 col-md-4">
        <div class="card p-3">
            <div class="text-muted small">Total orders</div>
            <div class="h4 m-0">@Model.TotalOrders</div>
        </div>
    </div>
    <div class="col-12 col-md-4">
        <div class="card p-3">
            <div class="text-muted small">Total units sold</div>
            <div class="h4 m-0">@Model.TotalUnitsSold</div>
        </div>
    </div>
    <div class="col-12 col-md-4">
        <div class="card p-3">
            <div class="text-muted small">Total revenue</div>
            <div class="h4 m-0">@Model.TotalRevenue.ToString("c")</div>
        </div>
    </div>
</div>

<div class="card p-3 p-md-4">
    @if (!Model.TopProducts.Any())
    {
        <div class="empty-state">
            <h5 class="mb-2">Sin ventas en este rango</h5>
            <p class="text-muted mb-0">No hay lineas de orden para mostrar.</p>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead>
                    <tr>
                        <th>Product</th>
                        <th class="text-end">Quantity sold</th>
                        <th class="text-end">Revenue</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.TopProducts)
                    {
                        <tr>
                            <td class="fw-semibold">@item.ProductName</td>
                            <td class="text-end">@item.TotalQuantitySold</td>
                            <td class="text-end">@item.TotalRevenue.ToString("c")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>
