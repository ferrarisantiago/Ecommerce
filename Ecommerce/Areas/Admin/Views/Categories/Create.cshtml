@model Ecommerce_Modelos.Categoria

<div class="card p-4">
    <h2 class="mb-3">Crear categoria</h2>
    <form method="post">
        <div asp-validation-summary="ModelOnly" class="text-danger mb-2"></div>

        <div class="mb-3">
            <label asp-for="NombreCategoria" class="form-label"></label>
            <input asp-for="NombreCategoria" class="form-control" />
            <span asp-validation-for="NombreCategoria" class="text-danger"></span>
        </div>
        <div class="mb-3">
            <label asp-for="MostrarOrden" class="form-label"></label>
            <input asp-for="MostrarOrden" class="form-control" />
            <span asp-validation-for="MostrarOrden" class="text-danger"></span>
        </div>

        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-primary">Crear</button>
            <a asp-area="Admin" asp-controller="Categories" asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
