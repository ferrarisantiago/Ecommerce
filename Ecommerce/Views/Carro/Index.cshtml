@model List<Ecommerce_Modelos.Producto>
@using Ecommerce_Utilidades

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3 m-0">Carrito</h1>
    <div class="d-flex gap-2">
        <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary">Seguir comprando</a>
        <a asp-action="Limpiar" asp-controller="Carro" class="btn btn-outline-danger">Vaciar</a>
    </div>
</div>

@if (!Model.Any())
{
    <div class="empty-state">
        <h4>Tu carrito esta vacio</h4>
        <p class="text-muted mb-3">Agrega productos desde el catalogo para continuar.</p>
        <a asp-controller="Home" asp-action="Index" class="btn btn-primary">Ir al catalogo</a>
    </div>
}
else
{
    <form asp-action="ActualizarCarro" method="post" class="card p-3 p-md-4">
        <div class="table-responsive">
            <table class="table align-middle">
                <thead>
                    <tr>
                        <th>Producto</th>
                        <th class="text-center">Precio</th>
                        <th class="text-center">Cantidad</th>
                        <th class="text-end">Subtotal</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @{
                        double total = 0;
                    }
                    @for (int i = 0; i < Model.Count; i++)
                    {
                        <input asp-for="@Model[i].Id" type="hidden" />
                        var subtotal = Model[i].Precio * Model[i].TempCantidad;
                        total += subtotal;

                        <tr>
                            <td>
                                <div class="d-flex align-items-center gap-3">
                                    @if (!string.IsNullOrWhiteSpace(Model[i].ImagenUrl))
                                    {
                                        <img src="@WC.ImagenRuta@Model[i].ImagenUrl" alt="@Model[i].NombreProducto" class="cart-thumb" />
                                    }
                                    <div>
                                        <div class="fw-semibold">@Model[i].NombreProducto</div>
                                        <small class="text-muted">@Model[i].DescripcionCorta</small>
                                    </div>
                                </div>
                            </td>
                            <td class="text-center">@Model[i].Precio.ToString("c")</td>
                            <td class="text-center" style="max-width:120px;">
                                <input asp-for="@Model[i].TempCantidad" min="1" max="@Model[i].Stock" class="form-control form-control-sm mx-auto" />
                                <small class="text-muted">Disponible: @Model[i].Stock</small>
                            </td>
                            <td class="text-end">@subtotal.ToString("c")</td>
                            <td class="text-end">
                                <a asp-action="Remover" asp-route-id="@Model[i].Id" class="btn btn-sm btn-outline-danger">Quitar</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="d-flex flex-wrap justify-content-between align-items-center mt-2 gap-2">
            <div class="h5 m-0">Total: @total.ToString("c")</div>
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-outline-primary">Actualizar carrito</button>
                <a asp-controller="Checkout" asp-action="Index" class="btn btn-primary">Ir a checkout</a>
            </div>
        </div>
    </form>
}
