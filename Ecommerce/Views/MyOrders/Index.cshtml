@model IEnumerable<Ecommerce_Modelos.Orden>

<h1 class="h3 mb-3">Mis pedidos</h1>

@if (!Model.Any())
{
    <div class="empty-state">
        <h4>Aun no tienes pedidos</h4>
        <p class="text-muted mb-3">Cuando completes una compra, aparecera aqui.</p>
        <a asp-controller="Home" asp-action="Index" class="btn btn-primary">Explorar catalogo</a>
    </div>
}
else
{
    <div class="table-responsive card p-2">
        <table class="table align-middle mb-0">
            <thead>
                <tr>
                    <th>Pedido</th>
                    <th>Fecha</th>
                    <th>Estado</th>
                    <th class="text-end">Total</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var order in Model)
                {
                    <tr>
                        <td>#@order.Id</td>
                        <td>@order.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</td>
                        <td><span class="badge text-bg-light border">@order.Estado</span></td>
                        <td class="text-end">@order.Total.ToString("c")</td>
                        <td class="text-end">
                            <a asp-action="Detail" asp-route-id="@order.Id" class="btn btn-sm btn-outline-primary">Ver detalle</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
