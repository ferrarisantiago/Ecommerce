@model Ecommerce_Modelos.ErrorViewModel
@{
    ViewData["Title"] = "Error";
}

<div class="card p-4 text-center">
    <h1 class="h3 mb-2">Ups, algo salio mal</h1>
    <p class="text-muted mb-3">@Model.FriendlyMessage</p>

    @if (Model.StatusCode.HasValue)
    {
        <p class="mb-2"><strong>Codigo:</strong> @Model.StatusCode</p>
    }

    @if (Model.ShowRequestId)
    {
        <p class="mb-3"><strong>Request ID:</strong> <code>@Model.RequestId</code></p>
    }

    <div class="d-flex justify-content-center gap-2">
        <a asp-controller="Home" asp-action="Index" class="btn btn-primary">Volver al inicio</a>
        <a asp-controller="Home" asp-action="Privacy" class="btn btn-outline-secondary">Ayuda</a>
    </div>
</div>
