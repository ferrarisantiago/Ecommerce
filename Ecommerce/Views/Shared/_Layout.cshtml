@using Microsoft.AspNetCore.Http
@using Microsoft.EntityFrameworkCore
@using Ecommerce_Utilidades
@inject IHttpContextAccessor HttpContextAccessor
@inject Ecommerce_Datos.Datos.ApplicationDbContext DbContext

@{
    var cart = HttpContextAccessor.HttpContext?.Session.Get<List<CarroCompras>>(WC.SessionCarroCompras) ?? new List<CarroCompras>();
    int cartCount = cart.Sum(i => i.Cantidad);
    int lowStockCount = 0;
    if (User.Identity?.IsAuthenticated ?? false && User.IsInRole(WC.AdminRole))
    {
        lowStockCount = DbContext.Productos
            .AsNoTracking()
            .Count(p => !p.IsDeleted && p.IsActive && p.Stock <= p.MinimumStockLevel);
    }
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Ecommerce</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/fontawesome/css/all.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/css/toastr.min.css" />
</head>
<body>
    <header class="site-header sticky-top">
        <nav class="navbar navbar-expand-lg navbar-dark">
            <div class="container-xl">
                <a class="navbar-brand d-flex align-items-center gap-2" asp-controller="Home" asp-action="Index">
                    <span class="brand-badge"><i class="fa-solid fa-bag-shopping"></i></span>
                    <span>Ecommerce</span>
                </a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav" aria-controls="mainNav" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="mainNav">
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Index">Catalogo</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link d-flex align-items-center gap-2" asp-controller="Carro" asp-action="Index">
                                <i class="fa-solid fa-cart-shopping"></i>
                                <span>Carrito</span>
                                <span class="cart-badge">@cartCount</span>
                            </a>
                        </li>
                        @if (User.Identity?.IsAuthenticated ?? false)
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="MyOrders" asp-action="Index">Mis pedidos</a>
                            </li>
                        }
                        @if (User.IsInRole(WC.AdminRole))
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle" href="#" id="adminMenu" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    Administracion
                                </a>
                                <ul class="dropdown-menu" aria-labelledby="adminMenu">
                                    <li><a class="dropdown-item" asp-area="Admin" asp-controller="Dashboard" asp-action="Index">Dashboard</a></li>
                                    <li><a class="dropdown-item" asp-area="Admin" asp-controller="Products" asp-action="Index">Productos</a></li>
                                    <li>
                                        <a class="dropdown-item d-flex justify-content-between align-items-center" asp-area="Admin" asp-controller="Dashboard" asp-action="StockAlerts">
                                            <span>Stock Alerts</span>
                                            @if (lowStockCount > 0)
                                            {
                                                <span class="badge text-bg-danger">@lowStockCount</span>
                                            }
                                        </a>
                                    </li>
                                    <li><a class="dropdown-item" asp-area="Admin" asp-controller="Dashboard" asp-action="SalesReport">Sales Report</a></li>
                                    <li><a class="dropdown-item" asp-area="Admin" asp-controller="Categories" asp-action="Index">Categorias</a></li>
                                    <li><a class="dropdown-item" asp-controller="Orden" asp-action="Index">Ordenes legacy</a></li>
                                    <li><a class="dropdown-item" asp-controller="Venta" asp-action="Index">Ventas</a></li>
                                </ul>
                            </li>
                        }
                    </ul>

                    <div class="d-flex align-items-center">
                        <partial name="_LoginPartial" />
                    </div>
                </div>
            </div>
        </nav>
    </header>

    <div class="container-xl page-shell">
        <main role="main" class="pb-4">
            <partial name="_Notification" />
            @RenderBody()
        </main>
    </div>

    <footer class="site-footer">
        <div class="container-xl d-flex justify-content-between flex-wrap gap-2">
            <span>&copy; @DateTime.Now.Year Ecommerce</span>
            <span>ASP.NET Core MVC Portfolio Build</span>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/js/toastr.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
