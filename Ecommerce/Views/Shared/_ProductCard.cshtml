@model Ecommerce_Modelos.Producto
@using Ecommerce_Utilidades

<article class="product-card">
    <a asp-controller="Home" asp-action="Detalle" asp-route-id="@Model.Id" class="product-card-image-wrap" aria-label="@Model.NombreProducto">
        @if (!string.IsNullOrWhiteSpace(Model.ImagenUrl))
        {
            <img class="product-card-image" src="@WC.ImagenRuta@Model.ImagenUrl" alt="@Model.NombreProducto" />
        }
        else
        {
            <div class="product-card-image placeholder">Sin imagen</div>
        }
    </a>

    <div class="product-card-body">
        <div class="d-flex justify-content-between align-items-start gap-2 mb-2">
            <h3 class="product-card-title">@Model.NombreProducto</h3>
            <span class="product-card-price">@Model.Precio.ToString("c")</span>
        </div>
        <div class="d-flex flex-wrap gap-2 mb-2">
            <span class="badge rounded-pill text-bg-light border">@Model.Categoria?.NombreCategoria</span>
            <span class="badge rounded-pill text-bg-light border">@Model.TipoAplicacion?.Nombre</span>
        </div>
        <p class="product-card-description">@Model.DescripcionCorta</p>
    </div>

    <div class="product-card-footer">
        @if (Model.Stock > 0)
        {
            <span class="stock in">En stock: @Model.Stock</span>
        }
        else
        {
            <span class="stock out">Sin stock</span>
        }
        <a asp-controller="Home" asp-action="Detalle" asp-route-id="@Model.Id" class="btn btn-sm btn-primary">Ver detalle</a>
    </div>
</article>
