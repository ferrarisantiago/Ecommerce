@model Ecommerce_Modelos.ViewModels.DetalleVM
@using Ecommerce_Utilidades

<section class="card p-3 p-md-4 mb-4">
    <form method="post" asp-action="Detalle">
        <input asp-for="Producto.Id" type="hidden" />

        <div class="row g-4">
            <div class="col-12 col-lg-6">
                <div class="product-detail-image-wrap mb-2">
                    @if (!string.IsNullOrWhiteSpace(Model.Producto.ImagenUrl))
                    {
                        <img src="@WC.ImagenRuta@Model.Producto.ImagenUrl" alt="@Model.Producto.NombreProducto" class="product-detail-image" />
                    }
                    else
                    {
                        <div class="product-detail-image placeholder">Sin imagen</div>
                    }
                </div>

                <div class="product-thumbs">
                    <button type="button" class="thumb active">
                        @if (!string.IsNullOrWhiteSpace(Model.Producto.ImagenUrl))
                        {
                            <img src="@WC.ImagenRuta@Model.Producto.ImagenUrl" alt="Miniatura de @Model.Producto.NombreProducto" />
                        }
                        else
                        {
                            <span>Sin imagen</span>
                        }
                    </button>
                </div>
            </div>

            <div class="col-12 col-lg-6">
                <div class="d-flex flex-wrap gap-2 mb-2">
                    <span class="badge text-bg-light border">@Model.Producto.Categoria?.NombreCategoria</span>
                    <span class="badge text-bg-light border">@Model.Producto.TipoAplicacion?.Nombre</span>
                </div>
                <h1 class="h3 mb-2">@Model.Producto.NombreProducto</h1>
                <p class="h4 text-primary mb-3">@Model.Producto.Precio.ToString("c")</p>
                <p class="text-muted">@Html.Raw(Model.Producto.DescripcionLarga)</p>

                <div class="mb-3">
                    @if (Model.Producto.Stock > 0)
                    {
                        <span class="stock in">In stock (@Model.Producto.Stock)</span>
                    }
                    else
                    {
                        <span class="stock out">Out of stock</span>
                    }
                </div>

                @if (Model.Producto.Stock > 0)
                {
                    <div class="mb-3">
                        <label asp-for="Producto.TempCantidad" class="form-label">Cantidad</label>
                        <input asp-for="Producto.TempCantidad" min="1" max="@Model.Producto.Stock" class="form-control" style="max-width:140px;" />
                        <span asp-validation-for="Producto.TempCantidad" class="text-danger"></span>
                    </div>
                }

                <div class="d-flex flex-wrap gap-2">
                    <a asp-action="Index" class="btn btn-outline-secondary">Volver al catalogo</a>
                    @if (Model.Producto.Stock <= 0)
                    {
                        <button type="button" class="btn btn-secondary" disabled>Sin stock</button>
                    }
                    else if (Model.ExisteEnCarro)
                    {
                        <a asp-action="RemoverDeCarro" asp-route-id="@Model.Producto.Id" class="btn btn-warning">Quitar del carrito</a>
                    }
                    else
                    {
                        <button type="submit" asp-route-id="@Model.Producto.Id" class="btn btn-primary">Agregar al carrito</button>
                    }
                </div>
            </div>
        </div>
    </form>
</section>

<section class="mt-4">
    <h2 class="h4 mb-3">Productos relacionados</h2>
    @if (!Model.RelatedProducts.Any())
    {
        <div class="empty-state">
            <h5 class="mb-2">Sin relacionados</h5>
            <p class="text-muted mb-0">No hay productos de la misma categoria por el momento.</p>
        </div>
    }
    else
    {
        <div class="product-grid related">
            @foreach (var product in Model.RelatedProducts)
            {
                <partial name="_ProductCard" model="product" />
            }
        </div>
    }
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
